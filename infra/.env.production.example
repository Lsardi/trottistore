# ─── DATABASE ─────────────────────────────────────────────
POSTGRES_USER=trottistore
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=trottistore
DATABASE_URL=postgresql://trottistore:CHANGE_ME_STRONG_PASSWORD@postgres:5432/trottistore

# ─── REDIS ────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SERVICES (ports internes Docker) ────────────────────
PORT_ECOMMERCE=3001
PORT_CRM=3002
PORT_ANALYTICS=3003
PORT_SAV=3004

# ─── DOMAIN ──────────────────────────────────────────────
DOMAIN=trottistore.fr
BASE_URL=https://trottistore.fr
API_URL=http://ecommerce:3001
API_CRM_URL=http://crm:3002
API_ANALYTICS_URL=http://analytics:3003
API_SAV_URL=http://sav:3004

# ─── STRIPE ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook endpoint: https://trottistore.fr/api/v1/checkout/webhook

# ─── EMAIL (Brevo) ───────────────────────────────────────
BREVO_API_KEY=xkeysib-...
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login
SMTP_PASS=your-brevo-smtp-key
MAIL_FROM=commandes@trottistore.fr
BREVO_SENDER_EMAIL=sav@trottistore.fr

# ─── FEATURE FLAGS ───────────────────────────────────────
FEATURE_CHECKOUT_EXPRESS=true
FEATURE_AUTO_NOTIFICATIONS=true

# ─── BRAND (white-label) ────────────────────────────────
NEXT_PUBLIC_BRAND_NAME=TROTTISTORE
NEXT_PUBLIC_BRAND_DOMAIN=trottistore.fr
NEXT_PUBLIC_BRAND_COLOR_NEON=00FFD1

# ─── ENVIRONMENT ─────────────────────────────────────────
NODE_ENV=production
