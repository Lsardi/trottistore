{
  "name": "trottistore",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "effect": "^3.20.0",
      "vite": ">=8.0.5",
      "defu": ">=6.1.5"
    }
  },
  "scripts": {
    "dev": "bash dev.sh",
    "agent:init": "bash scripts/git-agent-worktree.sh init",
    "agent:hooks": "bash scripts/git-agent-worktree.sh install-hooks",
    "agent:status": "bash scripts/git-agent-status.sh",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:project": "vitest run --project",
    "test:changed": "vitest run --changed",
    "test:smoke": "vitest run services/ecommerce/src/routes/smoke/smoke.test.ts services/crm/src/routes/smoke/authz.smoke.test.ts services/sav/src/routes/smoke/authz.smoke.test.ts services/analytics/src/routes/smoke/authz.smoke.test.ts",
    "test:watch": "vitest",
    "test:integration": "vitest run integration",
    "test:load": "tsx tests/load/load-test.ts",
    "db:push": "pnpm --filter @trottistore/database db:push",
    "db:migrate": "pnpm --filter @trottistore/database db:migrate",
    "db:deploy": "pnpm --filter @trottistore/database db:deploy",
    "db:studio": "pnpm --filter @trottistore/database studio",
    "db:seed:demo": "pnpm --filter @trottistore/scripts seed:demo",
    "db:seed": "pnpm --filter @trottistore/scripts seed",
    "crawl": "pnpm --filter @trottistore/scripts crawl"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/bcryptjs": "^2.4.6",
    "@vitest/coverage-v8": "^4.1.2",
    "autocannon": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "vite": "8.0.5",
    "vitest": "^4.1.2",
    "zod": "^3.25.76"
  }
}
