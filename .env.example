# ─── BASE DE DONNÉES ────────────────────────────────────────
DATABASE_URL="postgresql://trottistore:dev_password@localhost:5432/trottistore_dev"

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── CLICKHOUSE ─────────────────────────────────────────────
CLICKHOUSE_URL="http://localhost:8123"

# ─── MINIO (Object Storage) ────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9001
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="trottistore"

# ─── AUTH (JWT) ─────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-in-production-access-secret-32chars"
JWT_REFRESH_SECRET="change-me-in-production-refresh-secret-32chars"
COOKIE_SECRET="change-me-in-production-cookie-secret-32chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── SERVICES (ports) ──────────────────────────────────────
PORT_WEB=3000
PORT_ECOMMERCE=3001
PORT_CRM=3002
PORT_ANALYTICS=3003
PORT_SAV=3004

# ─── EMAIL (Brevo / Sendinblue) ────────────────────────────
BREVO_API_KEY=""
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
# En dev, utiliser Mailpit : SMTP_HOST=localhost SMTP_PORT=1025

# ─── SMS (Twilio) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── PAIEMENT (Stripe — Apple Pay, Google Pay, Link) ──────
STRIPE_SECRET_KEY=""          # sk_test_... or sk_live_...
STRIPE_PUBLISHABLE_KEY=""     # pk_test_... or pk_live_...
STRIPE_WEBHOOK_SECRET=""      # whsec_... — required for payment confirmations
# To get the webhook secret in dev: stripe listen --forward-to localhost:3001/api/v1/checkout/webhook

# ─── ANALYTICS ─────────────────────────────────────────────
GA4_MEASUREMENT_ID=""
META_PIXEL_ID=""

# ─── WHITE-LABEL (marque) ─────────────────────────────────
# Toutes les valeurs ci-dessous sont optionnelles.
# Les défauts correspondent à TrottiStore.
# Changez-les pour déployer sous un autre nom de marque.
NEXT_PUBLIC_BRAND_NAME="TROTTISTORE"
NEXT_PUBLIC_BRAND_NAME_PARTS="TROTTI,STORE"
NEXT_PUBLIC_BRAND_TAGLINE="Spécialiste trottinettes électriques depuis 2019"
NEXT_PUBLIC_BRAND_DOMAIN="trottistore.fr"
NEXT_PUBLIC_BRAND_SINCE="2019"
NEXT_PUBLIC_BRAND_EMAIL="contact@trottistore.fr"
NEXT_PUBLIC_BRAND_PHONE="06 04 46 30 55"
NEXT_PUBLIC_BRAND_PHONE_INTL="+33604463055"
NEXT_PUBLIC_BRAND_ADDRESS_STREET="18 bis Rue Mechin"
NEXT_PUBLIC_BRAND_ADDRESS_POSTAL="93450"
NEXT_PUBLIC_BRAND_ADDRESS_CITY="L'Île-Saint-Denis"
NEXT_PUBLIC_BRAND_ADDRESS_CITY_SHORT="L'ÎLE-SAINT-DENIS"
NEXT_PUBLIC_BRAND_SEO_TITLE="TrottiStore — Trottinettes electriques & Pieces detachees"
NEXT_PUBLIC_BRAND_SEO_TITLE_TEMPLATE="%s | TrottiStore"
NEXT_PUBLIC_BRAND_SEO_DESCRIPTION="Boutique specialisee trottinettes electriques, pieces detachees et reparation SAV."
NEXT_PUBLIC_BRAND_OG_URL="https://trottistore.fr"
# Couleurs (CSS hex sans #)
NEXT_PUBLIC_BRAND_COLOR_NEON="00FFD1"
NEXT_PUBLIC_BRAND_COLOR_VOID="0A0A0A"

# ─── FEATURE FLAGS ─────────────────────────────────────────
FEATURE_CHECKOUT_EXPRESS=true
FEATURE_AUTO_NOTIFICATIONS=true

# ─── ENVIRONNEMENT ────────────────────────────────────────
NODE_ENV="development"
BASE_URL="http://localhost:3000"
API_URL="http://localhost:3001"
