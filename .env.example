# ─── BASE DE DONNÉES ────────────────────────────────────────
DATABASE_URL="postgresql://trottistore:dev_password@localhost:5432/trottistore_dev"

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── CLICKHOUSE ─────────────────────────────────────────────
CLICKHOUSE_URL="http://localhost:8123"

# ─── MINIO (Object Storage) ────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9001
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="trottistore"

# ─── AUTH (JWT) ─────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-in-production-access-secret-32chars"
JWT_REFRESH_SECRET="change-me-in-production-refresh-secret-32chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── SERVICES (ports) ──────────────────────────────────────
PORT_WEB=3000
PORT_ECOMMERCE=3001
PORT_CRM=3002
PORT_ANALYTICS=3003
PORT_SAV=3004

# ─── EMAIL (Brevo / Sendinblue) ────────────────────────────
BREVO_API_KEY=""
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
# En dev, utiliser Mailpit : SMTP_HOST=localhost SMTP_PORT=1025

# ─── SMS (Twilio) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── PAIEMENT (Stripe — Apple Pay, Google Pay, Link) ──────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── ANALYTICS ─────────────────────────────────────────────
GA4_MEASUREMENT_ID=""
META_PIXEL_ID=""

# ─── ENVIRONNEMENT ────────────────────────────────────────
NODE_ENV="development"
BASE_URL="http://localhost:3000"
API_URL="http://localhost:3001"
